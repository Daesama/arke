# ============================================
# ARKE — Variables de Entorno
# Copia este archivo como .env.local y llena los valores
# ============================================

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Google Gemini (IA de imágenes - primario) ---
# Console: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIza...

# --- fal.ai (IA de imágenes - fallback) ---
# Dashboard: https://fal.ai/dashboard/keys
FAL_KEY=fal_...

# --- Anthropic Claude (chatbot) ---
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (DALL-E fallback) ---
OPENAI_API_KEY=sk-proj-...

# --- Wompi (pagos Colombia) ---
# Dashboard: https://comercios.wompi.co
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=test_events_...
WOMPI_INTEGRITY_SECRET=test_integrity_...
NEXT_PUBLIC_WOMPI_ENV=sandbox

# --- Resend (emails transaccionales) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AI_PROVIDER=gemini
